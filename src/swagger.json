            "type": "string",
            "example": "660c1d2e1f4b3c2a1a0b9999"
          },
          "name": {
            "type": "string",
            "example": "Carlos Silva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "carlos.silva@example.com"
          },
          "role": {
            "type": "string",
            "enum": [
              "user",
              "admin"
            ],
            "example": "user"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-02T11:15:00.000Z"
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "660c1d2e1f4b3c2a1a0b1234"
          },
          "title": {
            "type": "string",
            "example": "Workshop de Node.js e Swagger"
          },
          "description": {
            "type": "string",
            "example": "Aprenda a documentar APIs REST de forma eficiente e profissional utilizando Swagger e OpenAPI."
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "example": "2026-12-31T18:00:00.000Z"
          },
          "location": {
            "type": "string",
            "example": "Laboratório de Informática 3"
          },
          "maxParticipants": {
            "type": "integer",
            "example": 30
          },
          "category": {
            "type": "string",
            "example": "workshop"
          },
          "organizer": {
            "anyOf": [
              {
                "type": "string",
                "description": "ID do organizador"
              },
              {
                "type": "object",
                "properties": {
                  "_id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  }
                }
              }
            ],
            "example": {
              "_id": "660c1d2e1f4b3c2a1a0b9999",
              "name": "Carlos Silva",
              "email": "carlos.silva@example.com"
            }
          },
          "status": {
            "type": "string",
            "example": "ativo"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-02T11:16:00.000Z"
          }
        }
      },
      "Registration": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "660c1d2e1f4b3c2a1a0b5678"
          },
          "event": {
            "anyOf": [
              {
                "type": "string",
                "description": "ID do evento"
              },
              {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "date": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "location": {
                    "type": "string"
                  }
                }
              }
            ],
            "example": {
              "_id": "660c1d2e1f4b3c2a1a0b1234",
              "title": "Workshop de Node.js e Swagger",
              "date": "2026-12-31T18:00:00.000Z",
              "location": "Laboratório de Informática 3"
            }
          },
          "participant": {
            "anyOf": [
              {
                "type": "string",
                "description": "ID do participante"
              },
              {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  }
                }
              }
            ],
            "example": {
              "_id": "660c1d2e1f4b3c2a1a0b9999",
              "name": "Carlos Silva",
              "email": "carlos.silva@example.com"
            }
          },
          "status": {
            "type": "string",
            "example": "confirmada"
          },
          "registeredAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-02T11:17:00.000Z"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
