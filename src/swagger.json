{
  "openapi": "3.0.0",
  "info": {
    "title": "API de Loja",
    "description": "Documentação da API para o sistema de Loja com Clientes, Produtos, Categorias e Pedidos. Migrado para MySQL.",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Usuario": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "senha": {
            "type": "string"
          }
        }
      },
      "Cliente": {
        "type": "object",
        "properties": {
          "id_cliente": {
            "type": "integer"
          },
          "nome": {
            "type": "string"
          },
          "telefone": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Produto": {
        "type": "object",
        "properties": {
          "id_produto": {
            "type": "integer"
          },
          "nome": {
            "type": "string"
          },
          "valor": {
            "type": "number"
          },
          "estoque": {
            "type": "integer"
          },
          "categorias_id_categoria": {
            "type": "integer"
          },
          "categoria_nome": {
            "type": "string"
          }
        }
      },
      "Categoria": {
        "type": "object",
        "properties": {
          "id_categoria": {
            "type": "integer"
          },
          "nome": {
            "type": "string"
          }
        }
      },
      "Pedido": {
        "type": "object",
        "properties": {
          "id_pedido": {
            "type": "integer"
          },
          "data": {
            "type": "string",
            "format": "date-time"
          },
          "clientes_id_cliente": {
            "type": "integer"
          },
          "cliente_nome": {
            "type": "string"
          },
          "itens": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProdutoPedido"
            }
          }
        }
      },
      "ProdutoPedido": {
        "type": "object",
        "properties": {
          "produtos_id_produto": {
            "type": "integer"
          },
          "pedidos_id_pedido": {
            "type": "integer"
          },
          "quantidade": {
            "type": "integer"
          },
          "valor": {
            "type": "number"
          },
          "produto_nome": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Sistema",
      "description": "Rotas de sistema e verificação"
    },
    {
      "name": "Auth",
      "description": "Autenticação"
    },
    {
      "name": "Clientes",
      "description": "Gerenciamento de clientes"
    },
    {
      "name": "Categorias",
      "description": "Gerenciamento de categorias de produtos"
    },
    {
      "name": "Produtos",
      "description": "Gerenciamento de produtos"
    },
    {
      "name": "Pedidos",
      "description": "Gerenciamento de pedidos e vendas"
    }
  ],
  "paths": {
    "/api/versao": {
      "get": {
        "summary": "Obter a versão da API",
        "tags": [
          "Sistema"
        ],
        "responses": {
          "200": {
            "description": "Retorna a versão e o status da API."
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Registrar usuário",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "senha": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuário registrado."
          },
          "400": {
            "description": "Erro de validação."
          },
          "500": {
            "description": "Erro no servidor."
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login do usuário",
        "tags": [
          "Auth"
        ],
