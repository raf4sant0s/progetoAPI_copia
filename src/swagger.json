{
  "openapi": "3.0.0",
  "info": {
    "title": "API REST - Sistema de Gestão de Eventos",
    "description": "Esta é a documentação completa e interativa da API REST para o Sistema de Gestão de Eventos. A API permite gerenciar usuários (registro e autenticação), eventos (CRUD completo com controle de acesso de organizador) e inscrições (inscrição, cancelamento e listagem de participantes).",
    "version": "1.0.0",
    "contact": {
      "name": "Equipe de Desenvolvimento de Eventos",
      "email": "desenvolvimento@gestaoeventos.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor de Desenvolvimento Local"
    }
  ],
  "tags": [
    {
      "name": "Autenticação",
      "description": "Endpoints relacionados ao registro de novos usuários e login."
    },
    {
      "name": "Eventos",
      "description": "Endpoints do CRUD principal de Eventos (necessita de autenticação)."
    },
    {
      "name": "Inscrições",
      "description": "Endpoints para inscrição em eventos e controle de participantes (necessita de autenticação)."
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Registrar um novo usuário",
        "description": "Cadastra um novo usuário no sistema. Por padrão, o novo usuário recebe a role 'user'.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "email",
                  "password"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 3,
                    "example": "Carlos Silva"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "carlos.silva@example.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "minLength": 6,
                    "example": "senha123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuário registrado com sucesso!",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Usuário registrado com sucesso!"
                    },
                    "user": {
                      "$ref": "#/components/schemas/User"
                    },
                    "token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Dados de entrada inválidos ou email já cadastrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Realizar login de usuário",
        "description": "Valida as credenciais do usuário e retorna um token JWT de acesso que expira em 24h.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "carlos.silva@example.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "senha123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso!",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Login realizado com sucesso!"
                    },
                    "user": {
                      "$ref": "#/components/schemas/User"
                    },
                    "token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Email e senha são obrigatórios.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Credenciais inválidas.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/events": {
      "get": {
        "tags": [
          "Eventos"
        ],
        "summary": "Listar todos os eventos",
        "description": "Retorna uma lista contendo todos os eventos cadastrados na plataforma ordenados por data de forma crescente. Requer autenticação por token.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de eventos retornada com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": {
                      "type": "integer",
                      "example": 2
                    },
                    "events": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Event"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado. Token ausente ou inválido.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Eventos"
        ],
        "summary": "Criar um novo evento",
        "description": "Cria um novo evento no sistema, vinculando o usuário autenticado como o organizador. A data do evento deve ser no futuro. Requer autenticação por token.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "description",
                  "date",
                  "location",
                  "maxParticipants",
                  "category"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 100,
                    "example": "Workshop de Node.js e Swagger"
                  },
                  "description": {
                    "type": "string",
                    "minLength": 10,
                    "maxLength": 1000,
                    "example": "Aprenda a documentar APIs REST de forma eficiente e profissional utilizando Swagger e OpenAPI."
                  },
                  "date": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-12-31T18:00:00.000Z"
                  },
                  "location": {
                    "type": "string",
                    "example": "Laboratório de Informática 3"
                  },
                  "maxParticipants": {
                    "type": "integer",
                    "minimum": 1,
                    "example": 30
                  },
                  "category": {
                    "type": "string",
                    "enum": [
                      "conferencia",
                      "workshop",
                      "seminario",
                      "meetup",
                      "outro"
                    ],
                    "example": "workshop"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "ativo",
                      "cancelado",
                      "concluido"
                    ],
                    "default": "ativo",
                    "example": "ativo"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Evento criado com sucesso!",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Evento criado com sucesso!"
                    },
                    "event": {
                      "$ref": "#/components/schemas/Event"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erros de validação (ex: campos em falta, data no passado ou categoria inválida).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado. Token ausente ou inválido.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/events/{id}": {
      "get": {
        "tags": [
          "Eventos"
        ],
        "summary": "Buscar evento por ID",
        "description": "Busca e retorna detalhes de um evento específico através do seu ID no formato de ObjectId do MongoDB. Requer autenticação por token.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID único do Evento",
            "schema": {
              "type": "string",
              "example": "660c1d2e1f4b3c2a1a0b1234"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Dados do evento detalhados.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "400": {
            "description": "ID inválido.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado. Token ausente ou inválido.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Evento não encontrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Eventos"
        ],
        "summary": "Atualizar um evento por ID",
        "description": "Permite que apenas o organizador original do evento atualize suas propriedades. Requer autenticação por token.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID único do Evento",
            "schema": {
              "type": "string",
              "example": "660c1d2e1f4b3c2a1a0b1234"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 100,
                    "example": "Workshop de Node.js Avançado"
                  },
                  "description": {
                    "type": "string",
                    "minLength": 10,
                    "maxLength": 1000,
                    "example": "Aprenda arquiteturas avançadas de APIs Rest Express no Node.js."
                  },
                  "date": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-12-31T20:00:00.000Z"
                  },
                  "location": {
                    "type": "string",
                    "example": "Laboratório de Informática 4"
                  },
                  "maxParticipants": {
                    "type": "integer",
                    "minimum": 1,
                    "example": 40
                  },
                  "category": {
                    "type": "string",
                    "enum": [
                      "conferencia",
                      "workshop",
                      "seminario",
                      "meetup",
                      "outro"
                    ],
                    "example": "workshop"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "ativo",
                      "cancelado",
                      "concluido"
                    ],
                    "example": "ativo"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Evento atualizado com sucesso!",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Evento atualizado com sucesso!"
                    },
                    "event": {
                      "$ref": "#/components/schemas/Event"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "ID inválido ou erro de validação nos dados fornecidos.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado. Token ausente ou inválido.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Acesso proibido. Apenas o organizador do evento pode editá-lo.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Evento não encontrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Eventos"
        ],
        "summary": "Excluir um evento por ID",
        "description": "Permite que apenas o organizador original delete permanentemente o evento cadastrado. Requer autenticação por token.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID único do Evento",
            "schema": {
              "type": "string",
              "example": "660c1d2e1f4b3c2a1a0b1234"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Evento deletado com sucesso!",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Evento deletado com sucesso!"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "ID inválido.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado. Token ausente ou inválido.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Acesso proibido. Apenas o organizador do evento pode deletá-lo.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Evento não encontrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/registrations": {
      "post": {
        "tags": [
          "Inscrições"
        ],
        "summary": "Inscrever-se em um evento",
        "description": "Cria ou reativa uma inscrição para o usuário autenticado em um evento especificado. O evento deve estar 'ativo' e possuir vagas disponíveis. Requer autenticação por token.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "eventId"
                ],
                "properties": {
                  "eventId": {
                    "type": "string",
                    "description": "ID único do Evento",
                    "example": "660c1d2e1f4b3c2a1a0b1234"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Inscrição reativada com sucesso (caso já tivesse uma inscrição cancelada).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Inscrição realizada com sucesso!"
                    },
                    "registration": {
                      "$ref": "#/components/schemas/Registration"
                    }
                  }
                }
              }
            }
          },
          "201": {
            "description": "Inscrição realizada com sucesso!",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Inscrição realizada com sucesso!"
                    },
                    "registration": {
                      "$ref": "#/components/schemas/Registration"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "ID de evento em falta ou inválido, evento não está ativo, ou evento lotado/usuário já inscrito.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado. Token ausente ou inválido.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Evento não encontrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/registrations/my": {
      "get": {
        "tags": [
          "Inscrições"
        ],
        "summary": "Listar minhas inscrições",
        "description": "Retorna uma lista contendo todas as inscrições ativas (status: 'confirmada') realizadas pelo usuário autenticado. Requer autenticação por token.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de inscrições do próprio usuário.",
