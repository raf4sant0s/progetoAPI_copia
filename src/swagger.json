                  "properties": {
                    "total": {
                      "type": "integer",
                      "example": 1
                    },
                    "registrations": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Registration"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado. Token ausente ou inválido.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/registrations/event/{eventId}": {
      "get": {
        "tags": [
          "Inscrições"
        ],
        "summary": "Listar inscritos de um evento",
        "description": "Retorna uma lista de todas as inscrições confirmadas para um evento específico. Requer autenticação por token.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "eventId",
            "in": "path",
            "required": true,
            "description": "ID único do Evento",
            "schema": {
              "type": "string",
              "example": "660c1d2e1f4b3c2a1a0b1234"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de inscritos no evento retornado.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": {
                      "type": "integer",
                      "example": 5
                    },
                    "registrations": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Registration"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "ID do evento inválido.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado. Token ausente ou inválido.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/registrations/{id}": {
      "delete": {
        "tags": [
          "Inscrições"
        ],
        "summary": "Cancelar uma inscrição por ID",
        "description": "Altera o status da inscrição para 'cancelada'. Apenas o participante dono da inscrição pode realizar esta operação. Requer autenticação por token.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID único da Inscrição",
            "schema": {
              "type": "string",
              "example": "660c1d2e1f4b3c2a1a0b5678"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Inscrição cancelada com sucesso!",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Inscrição cancelada com sucesso!"
                    },
                    "registration": {
                      "$ref": "#/components/schemas/Registration"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "ID inválido ou inscrição já estava previamente cancelada.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado. Token ausente ou inválido.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Acesso proibido. O usuário logado só pode cancelar suas próprias inscrições.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Inscrição não encontrada.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Insira o token JWT gerado no endpoint de login ou registro. O formato deve ser apenas o token cru."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
